---
import Illustration from '../ui/Illustration.astro';

interface Props {
  titre: string;
  resume: string;
  href: string;
  star?: boolean;
  aVenir?: boolean;
  illustrationRef?: string;
}
const { titre, resume, href, star = false, aVenir = false, illustrationRef } = Astro.props;
const Tag = aVenir ? 'div' : 'a';
---

<Tag
  class:list={['onglet', { 'onglet--star': star, 'onglet--a-venir': aVenir }]}
  href={aVenir ? undefined : href}
>
  <span class="onglet__languette"></span>
  {illustrationRef && <Illustration ref={illustrationRef} alt={`Illustration ${titre}`} />}
  <h4>{titre}</h4>
  <p>{resume}</p>
  {aVenir && <span class="onglet__badge">À venir</span>}
</Tag>

<style>
  .onglet {
    display: block;
    position: relative;
    background-color: var(--c-papier);
    border: 1px solid var(--c-creme);
    padding: 1.5rem;
    text-decoration: none;
    color: var(--c-encre);
    transition: border-color 160ms ease;
  }
  a.onglet:hover {
    border-color: var(--c-brun-reliure);
  }
  .onglet__languette {
    position: absolute;
    top: -1px;
    left: 1.5rem;
    width: 2.5rem;
    height: 4px;
    background-color: var(--c-sauge);
  }
  .onglet--star .onglet__languette {
    background-color: var(--c-dore);
  }
  .onglet--a-venir {
    opacity: 0.7;
  }
  .onglet p {
    margin-bottom: 0;
    font-size: var(--t-small-size);
    color: var(--c-muted);
  }
  .onglet__badge {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--f-mono);
    font-size: var(--t-label-size);
    letter-spacing: var(--t-label-ls);
    text-transform: uppercase;
    color: var(--c-brun-reliure);
  }
</style>
