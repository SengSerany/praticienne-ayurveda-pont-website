---
interface Props {
  titre: string;
  promesse: string;
}
const { titre, promesse } = Astro.props;
---

<section class="bloc-lettre">
  <h3>{titre}</h3>
  <p>{promesse}</p>
  <form class="bloc-lettre__form" method="post" action="/api/lettre">
    <label class="bloc-lettre__label" for="email-lettre-bloc">Votre adresse email</label>
    <div class="bloc-lettre__ligne">
      <input
        id="email-lettre-bloc"
        name="email"
        type="email"
        required
        placeholder="prenom@exemple.fr"
      />
      <input
        type="text"
        name="site"
        class="bloc-lettre__hp"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <button type="submit">S'inscrire</button>
    </div>
  </form>
</section>

<style>
  .bloc-lettre {
    background-color: var(--c-papier-chaleur);
    border-left: 2px solid var(--c-brun-reliure);
    padding: var(--espace-section) clamp(1.5rem, 5vw, 4rem);
    max-width: var(--rythme-colonne-large);
  }
  .bloc-lettre__label {
    display: block;
    font-family: var(--f-mono);
    font-size: var(--t-label-size);
    letter-spacing: var(--t-label-ls);
    text-transform: uppercase;
    color: var(--c-brun-reliure);
    margin-bottom: 0.5rem;
  }
  .bloc-lettre__ligne {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .bloc-lettre__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
  }
  .bloc-lettre__ligne input[type='email'] {
    flex: 1 1 14rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--c-creme);
    background-color: var(--c-papier);
    font-family: var(--f-body);
    font-size: var(--t-body-size);
  }
  .bloc-lettre__ligne button {
    padding: var(--t-cta-pad);
    border: none;
    background-color: var(--c-sauge);
    color: var(--c-encre);
    font-family: var(--f-body);
    font-size: var(--t-cta-size);
    font-weight: var(--t-cta-weight);
    letter-spacing: var(--t-cta-ls);
    text-transform: uppercase;
    cursor: pointer;
  }
</style>
