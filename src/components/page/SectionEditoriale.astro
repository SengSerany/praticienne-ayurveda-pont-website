---
import Eyebrow from '../ui/Eyebrow.astro';

interface Props {
  numero?: string;
  surtitre: string;
  titre: string;
}
const { numero, surtitre, titre } = Astro.props;
const eyebrow = numero ? `§ ${numero} · ${surtitre}` : surtitre;
---

<section class="section-editoriale">
  <Eyebrow text={eyebrow} />
  <h2>{titre}</h2>
  <div class="section-editoriale__corps">
    <slot />
  </div>
  <div class="section-editoriale__marge">
    <slot name="marge" />
  </div>
</section>

<style>
  .section-editoriale {
    padding: var(--espace-section) clamp(1rem, 4vw, 3rem);
  }
  .section-editoriale h2 {
    margin-top: 0.5rem;
  }
  .section-editoriale__marge:empty {
    display: none;
  }
</style>
