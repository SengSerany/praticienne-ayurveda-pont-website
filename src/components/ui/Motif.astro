---
interface Props {
  variante?: '01' | '02' | '03';
}
const { variante = '01' } = Astro.props;
---

<div class:list={['motif', `motif--${variante}`]} role="separator" aria-hidden="true">
  {
    variante === '01' && (
      <svg
        width="120"
        height="16"
        viewBox="0 0 120 16"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line x1="0" y1="8" x2="48" y2="8" stroke="currentColor" stroke-width="1" />
        <path
          d="M60 2 C56 6, 56 10, 60 14 C64 10, 64 6, 60 2 Z"
          fill="currentColor"
          opacity="0.7"
        />
        <line x1="72" y1="8" x2="120" y2="8" stroke="currentColor" stroke-width="1" />
      </svg>
    )
  }
  {
    variante === '02' && (
      <svg
        width="16"
        height="40"
        viewBox="0 0 16 40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M2 0 L14 0 L14 34 L8 28 L2 34 Z" fill="currentColor" opacity="0.85" />
      </svg>
    )
  }
  {
    variante === '03' && (
      <svg
        width="20"
        height="24"
        viewBox="0 0 20 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <circle cx="10" cy="6" r="5" fill="currentColor" opacity="0.85" />
        <line x1="10" y1="11" x2="10" y2="24" stroke="currentColor" stroke-width="1.2" />
      </svg>
    )
  }
</div>

<style>
  .motif {
    display: flex;
    justify-content: flex-start;
    color: var(--c-brun-reliure);
  }
  .motif--01 {
    margin: var(--espace-section) 0;
  }
  .motif--02 {
    color: var(--c-sauge);
  }
  .motif--03 {
    color: var(--c-brun-reliure);
  }
</style>
